# Local static development defaults.
# Copy to `.env` only for local file-server settings. Do not commit `.env`.

STATIC_DEV_HOST=localhost
STATIC_DEV_PORT=8788
STATIC_DEV_PROXY=0

# Optional proxy debug targets, used only when STATIC_DEV_PROXY=1.
# STOREFRONT_XAPI_REMOTE=https://xapi.selldone.com
# API_REMOTE=https://api.selldone.com
# SELLDONE_REMOTE=https://selldone.com